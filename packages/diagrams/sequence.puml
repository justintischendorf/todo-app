@startuml
autonumber
actor Client
participant "REST API" as API
participant "Redis Cache" as Cache
participant "Redis Queue" as Queue
participant "Worker (plainTS)" as Worker
participant "Prisma ORM" as ORM
database "PostgreSQL" as DB

== GET /api/todos ==
Client -> API: GET /api/todos
API -> ORM: findMany(todos)
ORM -> DB: SELECT * FROM todos
DB --> ORM: todos
ORM --> API: todos
API --> Client: todos

== GET /api/todos/:id ==
Client -> API: GET /api/todos/:id
API -> Cache: GET todo:id

alt Todo im Cache vorhanden
    Cache --> API: todo
    API --> Client: todo
else Todo nicht im Cache
    Cache --> API: null
    API -> ORM: findUnique(todo:id)
    ORM -> DB: SELECT todo WHERE id
    DB --> ORM: todo
    ORM --> API: todo
    API -> Cache: SET todo:id
    API --> Client: todo
end

== POST /api/todos ==
Client -> API: POST /api/todos (todo)
API -> Queue: PUSH todo

loop Worker verarbeitet Queue
    Worker -> Queue: POP todo
    Worker -> ORM: create(todo)
    ORM -> DB: INSERT todo
    DB --> ORM: success
    ORM --> Worker: todo
    Worker -> Cache: SET todo:id
end

== PATCH /api/todos/:id ==
Client -> API: PATCH /api/todos/:id (updated data)
API -> Cache: UPDATE todo:id
API -> ORM: update(todo:id)
ORM -> DB: UPDATE todo
DB --> ORM: success
ORM --> API: updated todo
API --> Client: updated todo

== DELETE /api/todos ==
Client -> API: DELETE /api/todos
API -> Cache: DELETE all todos
API -> ORM: deleteMany(todos)
ORM -> DB: DELETE FROM todos
DB --> ORM: success
ORM --> API: success
API --> Client: success

== DELETE /api/todos/:id ==
Client -> API: DELETE /api/todos/:id
API -> Cache: DELETE todo:id
API -> ORM: delete(todo:id)
ORM -> DB: DELETE todo WHERE id
DB --> ORM: success
ORM --> API: success
API --> Client: success

@enduml