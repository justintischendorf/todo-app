@startuml

actor User
participant "Angular Frontend" as FE
participant "REST API" as API
participant "Redis Cache" as Cache
participant "Redis Queue" as Queue
participant "Worker (plainTS)" as Worker
participant "Prisma ORM" as ORM
database "PostgreSQL" as DB

== GET /api/todos ==
User -> FE: Open page / trigger action
FE -> API: GET /api/todos
API -> ORM: findMany(todos)
ORM -> DB: SELECT * FROM todos
DB --> ORM: todos
ORM --> API: todos
API --> FE: todos
FE --> User: Render todo list

== GET /api/todos/:id ==
User -> FE: Select todo
FE -> API: GET /api/todos/:id
API -> Cache: GET todo:id

alt Todo found in cache
    Cache --> API: todo
    API --> FE: todo
    FE --> User: Display todo
else Todo not in cache
    Cache --> API: null
    API -> ORM: findUnique(todo:id)
    ORM -> DB: SELECT todo WHERE id
    DB --> ORM: todo
    ORM --> API: todo
    API -> Cache: SET todo:id
    API --> FE: todo
    FE --> User: Display todo
end

== POST /api/todos ==
User -> FE: Create new todo
FE -> API: POST /api/todos (todo)
API -> Queue: PUSH todo

loop Worker processes queue
    Worker -> Queue: POP todo
    Worker -> ORM: create(todo)
    ORM -> DB: INSERT todo
    DB --> ORM: success
    ORM --> Worker: todo
    Worker -> Cache: SET todo:id
end

API --> FE: 202 Accepted
FE --> User: Todo will appear after refresh

== PATCH /api/todos/:id ==
User -> FE: Edit todo
FE -> API: PATCH /api/todos/:id (updated data)
API -> Cache: UPDATE todo:id
API -> ORM: update(todo:id)
ORM -> DB: UPDATE todo
DB --> ORM: success
ORM --> API: updated todo
API --> FE: updated todo
FE --> User: Render updated todo

== DELETE /api/todos ==
User -> FE: Delete all todos
FE -> API: DELETE /api/todos
API -> Cache: DELETE all todos
API -> ORM: deleteMany(todos)
ORM -> DB: DELETE FROM todos
DB --> ORM: success
ORM --> API: success
API --> FE: success
FE -> FE: Reload page
FE --> User: Render empty todo list

== DELETE /api/todos/:id ==
User -> FE: Delete single todo
FE -> API: DELETE /api/todos/:id
API -> Cache: DELETE todo:id
API -> ORM: delete(todo:id)
ORM -> DB: DELETE todo WHERE id
DB --> ORM: success
ORM --> API: success
API --> FE: success
FE -> FE: Reload page
FE --> User: Render remaining todos

@enduml