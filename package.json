{
  "name": "simple-todo-app",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "rest": "bun run --watch app/rest/src/index.ts",
    "website": "cd app/website/todo-ang && ng serve",
    "docker:dev": "docker compose -f docker-compose-dev.yml up -d",
    "db:show": "bun prisma studio",
    "db:clear": "bunx prisma db execute --file ./packages/database/prisma/clear-all.sql"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.2",
    "elysia": "^1.4.25",
    "jsonwebtoken": "^9.0.0",
    "prisma": "^7.4.0"
  }
}
